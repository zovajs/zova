{
  "extends": "./tsconfig.base.esm",
  "compilerOptions": {
    "composite": false,
    "incremental": true,
    "sourcemap": false,
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "rewriteRelativeImportExtensions": false,
    "verbatimModuleSyntax": false
  },
  "references": [
  ],
  "include": [
    "src/**/*",
    ".zova-rest/**/*",
    "packages-zova/**/*",
    "packages-utils/zova-jsx",
    "packages-utils/logger"
  ]
}
