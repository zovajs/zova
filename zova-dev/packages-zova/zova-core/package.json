{
  "name": "zova-core",
  "type": "module",
  "version": "5.0.185",
  "description": "A vue3 framework with ioc",
  "publishConfig": {
    "access": "public"
  },
  "author": "zhennann",
  "license": "MIT",
  "homepage": "https://github.com/cabloy/zova#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "keywords": [
    "vue3",
    "ioc",
    "zova"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..require"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/compose": "^2.0.4",
    "@cabloy/extend": "^3.1.0",
    "@cabloy/json5": "^1.0.8",
    "@cabloy/localeutil": "^2.0.0",
    "@cabloy/logger": "workspace:^",
    "@cabloy/module-info": "^1.3.22",
    "@cabloy/set": "^1.0.7",
    "@cabloy/utils": "^1.0.37",
    "@cabloy/vue-compiler-sfc": "^3.5.14",
    "@cabloy/vue-reactivity": "^3.5.16",
    "@cabloy/vue-router": "^4.4.11",
    "@cabloy/vue-runtime-core": "^3.5.24",
    "@cabloy/vue-runtime-dom": "^3.5.13",
    "@cabloy/vue-server-renderer": "^3.5.18",
    "@cabloy/word-utils": "workspace:^",
    "@cabloy/zod-errors-custom": "^2.0.3",
    "@cabloy/zod-openapi": "^1.0.5",
    "@cabloy/zod-query": "^2.0.3",
    "@types/js-cookie": "^3.0.6",
    "@vue/reactivity": "^3.5.6",
    "@vue/runtime-core": "^3.5.6",
    "@vue/runtime-dom": "^3.5.6",
    "@vue/shared": "^3.5.6",
    "deep-equal": "^2.2.3",
    "reflect-metadata": "^0.2.2",
    "vue": "^3.5.6",
    "vue-plugin-render-freeze": "^2.0.2",
    "zod": "^4.1.5",
    "zova-shared": "^1.0.7"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "gitHead": "c90e59abc1bf445154a3fb32856f83783dc0eb39"
}
