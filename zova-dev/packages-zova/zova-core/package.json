{
  "name": "zova-core",
  "version": "5.1.16",
  "gitHead": "8cb2168b0a2607c216a4d9b81bc9e16088895fc5",
  "description": "A vue3 framework with ioc",
  "keywords": [
    "ioc",
    "vue3",
    "zova"
  ],
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "license": "MIT",
  "author": "zhennann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral --sourcemap && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/compose": "^2.1.4",
    "@cabloy/extend": "^3.2.3",
    "@cabloy/json5": "^1.1.4",
    "@cabloy/localeutil": "^2.1.3",
    "@cabloy/logger": "workspace:^",
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/utils": "^2.1.5",
    "@cabloy/vue-compiler-sfc": "^3.5.14",
    "@cabloy/vue-reactivity": "^3.5.16",
    "@cabloy/vue-router": "^4.4.16",
    "@cabloy/vue-runtime-core": "^3.5.51",
    "@cabloy/vue-runtime-dom": "^3.5.13",
    "@cabloy/vue-server-renderer": "^3.5.18",
    "@cabloy/word-utils": "workspace:^",
    "@cabloy/zod-errors-custom": "^2.1.3",
    "@cabloy/zod-openapi": "^1.1.5",
    "@cabloy/zod-query": "^2.1.3",
    "@types/js-cookie": "^3.0.6",
    "@vue/shared": "^3.5.32",
    "deep-equal": "^2.2.3",
    "reflect-metadata": "^0.2.2",
    "vue": "^3.5.32",
    "vue-plugin-render-freeze": "^2.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3",
    "vite": "^8.0.8"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..require"
    ]
  }
}
