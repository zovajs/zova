{
  "name": "zova-module-a-style",
  "version": "5.1.0",
  "gitHead": "f98cfc976a1569ca212000ced3f10f1a211bb97e",
  "description": "style",
  "keywords": [
    "Zova Module"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "cli",
    "dist",
    "src",
    "icons",
    "assets",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "csx": "^10.0.2",
    "typestyle": "^2.4.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-style",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {
      "a-model": "5.0.0"
    },
    "globalDependencies": {
      "csx": true,
      "typestyle": true
    },
    "onions": {
      "css": {
        "optionsGlobalInterfaceName": "IDecoratorCssOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-style",
        "boilerplate": "css/boilerplate"
      },
      "theme": {
        "optionsGlobalInterfaceName": "IDecoratorThemeOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-style",
        "boilerplate": "theme/boilerplate"
      }
    },
    "metas": {
      "themeHandler": {
        "boilerplate": "themeHandler/boilerplate"
      }
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "csx",
            "typestyle"
          ],
          "output": "typestyle"
        }
      ]
    }
  }
}
