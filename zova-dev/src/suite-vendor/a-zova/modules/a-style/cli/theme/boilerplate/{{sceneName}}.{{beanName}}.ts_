import type { IDecoratorThemeOptions, IThemeApplyParams, IThemeApplyResult, IThemeBase } from 'zova-module-a-style';
import type { ThemeToken } from 'zova-module-home-base';
import { BeanBase } from 'zova';
import { Theme } from 'zova-module-a-style';

export interface IThemeOptions<%=argv.beanNameCapitalize%> extends IDecoratorThemeOptions {}

@Theme<IThemeOptions<%=argv.beanNameCapitalize%>>()
export class Theme<%=argv.beanNameCapitalize%> extends BeanBase implements IThemeBase {
  async apply({ name: _name, dark: _dark }: IThemeApplyParams): Promise<IThemeApplyResult> {
    const token: ThemeToken = {};
    return { token };
  }
}
