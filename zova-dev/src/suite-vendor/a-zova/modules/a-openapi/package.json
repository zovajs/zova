{
  "name": "zova-module-a-openapi",
  "version": "5.1.2",
  "gitHead": "a1b13b06e259e4447ab2f361ec76941810bc4ad7",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "dist",
    "mock",
    "src",
    "icons",
    "assets",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@cabloy/json-schema-to-zod": "^2.6.4",
    "@zhennann/currency": "^2.0.4",
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..types[0]"
    ]
  },
  "title": "a-openapi",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {
      "a-model": "5.0.0"
    },
    "globalDependencies": {
      "openapi3-ts": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@cabloy/json-schema-to-zod",
            "openapi3-ts"
          ],
          "output": "openapi3"
        }
      ]
    }
  }
}
