{
  "name": "zova-module-a-zod",
  "type": "module",
  "version": "5.0.0",
  "title": "a-zod",
  "zovaModule": {
    "globalDependencies": {
      "zod": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@cabloy/zod-errors-custom",
            "@cabloy/zod-openapi",
            "@cabloy/zod-query",
            "zod/locales",
            "zod/v4",
            "zod/index.js"
          ],
          "output": "zod"
        }
      ]
    }
  },
  "description": "",
  "author": "",
  "keywords": [
    "Zova Module"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "mock"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {
    "@cabloy/zod-errors-custom": "^2.0.2",
    "@cabloy/zod-openapi": "^1.0.2",
    "@cabloy/zod-query": "^2.0.1",
    "zod": "^4.1.5"
  }
}
