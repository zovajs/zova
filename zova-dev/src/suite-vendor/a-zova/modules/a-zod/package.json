{
  "name": "zova-module-a-zod",
  "version": "5.0.0",
  "title": "a-zod",
  "zovaModule": {
    "capabilities": {
      "preload": true
    },
    "globalDependencies": {
      "zod": true
    }
  },
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "mock",
    "dist"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {
    "@cabloy/zod-errors-custom": "^1.0.1",
    "@cabloy/zod-query": "^1.0.1",
    "zod": "^3.23.8"
  }
}
