{
  "name": "zova-module-a-action",
  "version": "5.1.2",
  "gitHead": "a1b13b06e259e4447ab2f361ec76941810bc4ad7",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "src",
    "icons",
    "assets",
    "rest",
    "dist-cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist dist-cli tsconfig.build.tsbuildinfo tsconfig.cli.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..types[0]"
    ]
  },
  "title": "a-action",
  "zovaModule": {
    "onions": {
      "action": {
        "beanGeneral": true,
        "optionsGlobalInterfaceName": "IDecoratorActionOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-action",
        "boilerplate": "action/boilerplate",
        "metadataCustom": "action/metadata/generate.ts"
      }
    },
    "capabilities": {
      "monkey": true
    },
    "dependencies": {}
  }
}
