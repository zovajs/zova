{
  "name": "zova-module-a-pinia",
  "version": "5.1.1",
  "gitHead": "f98cfc976a1569ca212000ced3f10f1a211bb97e",
  "description": "pinia",
  "keywords": [
    "Zova Module"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "dist",
    "src",
    "icons",
    "assets",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "pinia": "^2.1.7"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-pinia",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    }
  }
}
