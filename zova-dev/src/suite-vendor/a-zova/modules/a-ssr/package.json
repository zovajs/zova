{
  "name": "zova-module-a-ssr",
  "version": "5.1.4",
  "gitHead": "e39b5585aa05ead6abb674f7db84dafd2a2c2004",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "dist",
    "mock",
    "src",
    "icons",
    "assets",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "devalue": "^5.6.2",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..types[0]",
      "exports.\\..import"
    ]
  },
  "title": "a-ssr",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    }
  }
}
