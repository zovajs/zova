import { BeanServiceBase, Service } from 'zova-module-a-api';

export interface Service<%=argv.beanNameCapitalize%>EchoResult {
  message: string;
}

@Service()
export class Service<%=argv.beanNameCapitalize%> extends BeanServiceBase {
  echo() {
    return this.$api.get<any, Service<%=argv.beanNameCapitalize%>EchoResult>('/<%=argv.beanName%>/echo');
  }
}
