{
  "name": "zova-module-a-api",
  "version": "5.0.0",
  "title": "a-api",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {
      "a-zova": "5.0.0"
    }
  },
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.tsx",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.tsx",
      "default": "./dist/index.jsx"
    },
    "./*": "./*"
  },
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "mock",
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {}
}
