{
  "name": "zova-module-a-api",
  "type": "module",
  "version": "5.0.0",
  "title": "a-api",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {},
    "onions": {
      "api": {
        "sceneIsolate": true,
        "scopeResource": true,
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "cli/api/boilerplate",
        "metadataCustom": "cli/api/metadata/generate.ts"
      }
    }
  },
  "description": "",
  "author": "",
  "keywords": [
    "Zova Module"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "files": [
    "cli",
    "dist",
    "mock",
    "src"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {}
}
