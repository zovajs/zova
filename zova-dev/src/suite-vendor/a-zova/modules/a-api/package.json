{
  "name": "zova-module-a-api",
  "version": "5.1.0",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "src",
    "icons",
    "assets",
    "rest",
    "dist-cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist dist-cli tsconfig.build.tsbuildinfo tsconfig.cli.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-api",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {
      "a-fetch": "5.0.0",
      "a-openapi": "5.0.0",
      "a-model": "5.0.0"
    },
    "onions": {
      "api": {
        "sceneIsolate": true,
        "scopeResource": true,
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "api/boilerplate",
        "metadataCustom": "api/metadata/generate.ts"
      },
      "apiMeta": {
        "sceneIsolate": true,
        "scopeResource": true,
        "beanGeneral": true,
        "optionsNone": true
      },
      "apiSchema": {
        "sceneIsolate": true,
        "scopeResource": true,
        "beanGeneral": true,
        "optionsNone": true
      }
    }
  }
}
