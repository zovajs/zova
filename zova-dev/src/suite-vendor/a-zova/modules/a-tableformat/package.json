{
  "name": "zova-module-a-tableformat",
  "type": "module",
  "version": "5.0.0",
  "title": "a-tableformat",
  "description": "",
  "author": "",
  "keywords": [
    "Zova Module"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "mock"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {
    "@zhennann/currency": "^2.0.0"
  },
  "zovaModule": {
    "onionsConfig": {
      "tableCellFormat": {
        "currency": {
          "type": "value",
          "match": "!!context.rest?.currency"
        },
        "fallback": {
          "type": "fallback"
        }
      }
    }
  }
}
