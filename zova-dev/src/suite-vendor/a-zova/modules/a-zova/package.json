{
  "name": "zova-module-a-zova",
  "version": "5.1.15",
  "gitHead": "8cb2168b0a2607c216a4d9b81bc9e16088895fc5",
  "description": "zova",
  "keywords": [
    "Zova Module"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "dist",
    "src",
    "icons",
    "assets",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@cabloy/compose": "^2.1.4",
    "@cabloy/deps": "^1.1.4",
    "@cabloy/json5": "^1.1.4",
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/utils": "^2.1.4",
    "@cabloy/vue-router": "^4.4.16",
    "@cabloy/word-utils": "workspace:^",
    "defu": "^6.1.7",
    "luxon": "^3.7.2",
    "zova-jsx": "workspace:^"
  },
  "devDependencies": {
    "@cabloy/cli": "^3.1.4",
    "@types/luxon": "^3.7.1",
    "clean-package": "^2.2.0",
    "fs-extra": "^11.3.4",
    "rimraf": "^6.1.3",
    "zova-openapi": "workspace:^"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "exports.\\..import"
    ]
  },
  "title": "a-zova",
  "zovaModule": {
    "dependencies": {
      "a-api": "5.0.0",
      "a-app": "5.0.0",
      "a-bean": "5.0.0",
      "a-behavior": "5.0.0",
      "a-boundary": "5.0.0",
      "a-currency": "5.0.0",
      "a-date": "5.0.0",
      "a-fetch": "5.0.0",
      "a-form": "5.0.0",
      "a-icon": "5.0.0",
      "a-interceptor": "5.0.0",
      "a-logger": "5.0.0",
      "a-meta": "5.0.0",
      "a-model": "5.0.0",
      "a-openapi": "5.0.0",
      "a-router": "5.0.0",
      "a-ssr": "5.0.0",
      "a-ssrhmr": "5.0.0",
      "a-style": "5.0.0",
      "a-table": "5.0.0",
      "a-zod": "5.0.0"
    },
    "globalDependencies": {
      "@cabloy/compose": true,
      "@cabloy/deps": true,
      "@cabloy/json5": true,
      "@cabloy/module-info": true,
      "@cabloy/utils": true,
      "@cabloy/vue-router": true,
      "@cabloy/word-utils": true,
      "defu": true,
      "luxon": true,
      "zova-jsx": true
    },
    "globalDependenciesDev": {
      "@cabloy/cli": true,
      "@types/luxon": true,
      "fs-extra": true,
      "zova-openapi": true
    }
  }
}
