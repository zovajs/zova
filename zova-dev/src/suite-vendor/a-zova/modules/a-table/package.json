{
  "name": "zova-module-a-table",
  "version": "5.1.0",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "rest",
    "src",
    "icons",
    "assets",
    "dist-cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist dist-cli tsconfig.build.tsbuildinfo tsconfig.cli.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/vue-table": "^8.21.3"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-table",
  "zovaModule": {
    "globalDependencies": {
      "@tanstack/table-core": true,
      "@tanstack/vue-table": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@tanstack/table-core",
            "@tanstack/vue-table"
          ],
          "output": "tanstack-table"
        }
      ]
    },
    "onions": {
      "tableCell": {
        "beanGeneral": true,
        "optionsGlobalInterfaceName": "IDecoratorTableCellOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-table",
        "boilerplate": "tableCell/boilerplate",
        "metadataCustom": "tableCell/metadata/generate.ts"
      }
    }
  },
  "gitHead": "f98cfc976a1569ca212000ced3f10f1a211bb97e"
}
