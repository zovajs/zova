{
  "name": "zova-module-a-table",
  "type": "module",
  "version": "5.0.0",
  "title": "a-table",
  "zovaModule": {
    "globalDependencies": {
      "@tanstack/table-core": true,
      "@tanstack/vue-table": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@tanstack/table-core",
            "@tanstack/vue-table"
          ],
          "output": "tanstack-table"
        }
      ]
    },
    "onions": {
      "tableCellFormat": {
        "optionsPackage": true,
        "optionsMatchCeljs": true,
        "optionsGlobalInterfaceName": "IDecoratorTableCellFormatOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-table",
        "boilerplate": "cli/tableCellFormat/boilerplate"
      }
    },
    "onionsConfig": {
      "tableCellFormat": {
        "currency": {
          "dependencies": "a-table:fallback",
          "match": "!!(property.rest && property.rest.currency)"
        },
        "fallback": {}
      }
    }
  },
  "description": "",
  "author": "",
  "keywords": [
    "Zova Module"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "mock"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/vue-table": "^8.21.3"
  }
}
