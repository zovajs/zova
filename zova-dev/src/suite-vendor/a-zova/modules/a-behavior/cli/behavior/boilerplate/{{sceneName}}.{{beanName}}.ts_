import { VNode } from 'vue';
import { BeanBase } from 'zova';
import {
  Behavior,
  IBehaviorExecute,
  IBehaviorTag,
  IDecoratorBehaviorOptions,
  NextBehavior,
} from 'zova-module-a-behavior';

export interface IBehaviorPropsInput<%=argv.beanNameCapitalize%> {}

export interface IBehaviorPropsOutput<%=argv.beanNameCapitalize%> {}

export interface IBehaviorOptions<%=argv.beanNameCapitalize%> extends IDecoratorBehaviorOptions {}

@Behavior<IBehaviorOptions<%=argv.beanNameCapitalize%>>()
export class Behavior<%=argv.beanNameCapitalize%>
  extends BeanBase
  implements IBehaviorExecute<IBehaviorPropsInput<%=argv.beanNameCapitalize%>, IBehaviorPropsOutput<%=argv.beanNameCapitalize%>>
{
  execute(
    _props: IBehaviorPropsInput<%=argv.beanNameCapitalize%>,
    _options: IBehaviorOptions<%=argv.beanNameCapitalize%>,
    _behaviorTag: IBehaviorTag,
    next: NextBehavior<IBehaviorPropsOutput<%=argv.beanNameCapitalize%>>,
  ): VNode {
    return next();
  }
}
