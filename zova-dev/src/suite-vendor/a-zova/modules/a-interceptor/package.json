{
  "name": "zova-module-a-interceptor",
  "type": "module",
  "version": "5.0.0",
  "title": "a-interceptor",
  "description": "",
  "author": "",
  "keywords": [
    "Zova Module"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
