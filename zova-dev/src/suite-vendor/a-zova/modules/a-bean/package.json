{
  "name": "zova-module-a-bean",
  "version": "5.1.10",
  "gitHead": "8cb2168b0a2607c216a4d9b81bc9e16088895fc5",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "src",
    "icons",
    "assets",
    "rest",
    "dist-cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist dist-cli tsconfig.build.tsbuildinfo tsconfig.cli.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json && tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "globby": "^14.1.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-bean",
  "zovaModule": {
    "capabilities": {
      "preload": true,
      "monkey": true
    },
    "onions": {
      "sys": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "sys/boilerplate"
      },
      "bean": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "bean/boilerplate"
      },
      "data": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "data/boilerplate"
      },
      "service": {
        "sceneIsolate": true,
        "beanGeneral": true,
        "optionsNone": false,
        "optionsGlobalInterfaceFrom": "zova-module-a-bean",
        "boilerplate": "service/boilerplate"
      },
      "store": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "store/boilerplate"
      },
      "tool": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "tool/boilerplate"
      },
      "controller": {
        "beanGeneral": false,
        "optionsNone": true,
        "metadataCustom": "controller/metadata/generate.ts"
      },
      "render": {
        "beanGeneral": false,
        "optionsNone": true
      },
      "style": {
        "beanGeneral": false,
        "optionsNone": true
      },
      "aop": {
        "optionsPackage": true,
        "optionsGlobalInterfaceName": "IDecoratorAopOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-bean",
        "boilerplate": "aop/boilerplate"
      },
      "aopMethod": {
        "optionsGlobalInterfaceName": "IDecoratorAopMethodOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-bean",
        "boilerplate": "aopMethod/boilerplate"
      }
    },
    "dependencies": {}
  }
}
