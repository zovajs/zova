{
  "name": "zova-module-a-bean",
  "version": "5.0.0",
  "title": "a-bean",
  "zovaModule": {
    "onions": {
      "bean": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "cli/bean/boilerplate"
      },
      "data": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "cli/data/boilerplate"
      },
      "local": {
        "beanGeneral": false,
        "optionsNone": true,
        "boilerplate": "cli/local/boilerplate"
      },
      "store": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "cli/store/boilerplate"
      },
      "tool": {
        "beanGeneral": true,
        "optionsNone": true,
        "boilerplate": "cli/tool/boilerplate"
      },
      "controller": {
        "beanGeneral": false,
        "optionsNone": true,
        "metadataCustom": "cli/controller/metadata/generate.ts"
      },
      "render": {
        "beanGeneral": false,
        "optionsNone": true,
        "metadataCustom": "cli/render/metadata/generate.ts"
      },
      "style": {
        "beanGeneral": false,
        "optionsNone": true
      }
    }
  },
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "mock",
    "dist",
    "cli"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {}
}
