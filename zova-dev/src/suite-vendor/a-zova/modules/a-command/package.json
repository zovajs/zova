{
  "name": "zova-module-a-command",
  "version": "5.1.19",
  "gitHead": "8cb2168b0a2607c216a4d9b81bc9e16088895fc5",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "src",
    "icons",
    "assets"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-command",
  "zovaModule": {
    "onions": {
      "command": {
        "beanGeneral": true,
        "optionsGlobalInterfaceName": "IDecoratorCommandOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-command",
        "boilerplate": "command/boilerplate",
        "boilerplateCommandBulk": "commandBulk/boilerplate",
        "boilerplateCommandRow": "commandRow/boilerplate"
      }
    },
    "capabilities": {
      "monkey": true
    },
    "dependencies": {}
  }
}
