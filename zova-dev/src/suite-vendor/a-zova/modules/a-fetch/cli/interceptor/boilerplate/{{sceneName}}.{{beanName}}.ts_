import { BeanInterceptorBase, IDecoratorInterceptorOptions, Interceptor } from 'zova-module-a-fetch';

export interface IInterceptorOptions<%=argv.beanNameCapitalize%> extends IDecoratorInterceptorOptions {}

@Interceptor<IInterceptorOptions<%=argv.beanNameCapitalize%>>()
export class Interceptor<%=argv.beanNameCapitalize%> extends BeanInterceptorBase<IInterceptorOptions<%=argv.beanNameCapitalize%>> {}
