{
  "name": "zova-module-a-fetch",
  "version": "5.1.7",
  "gitHead": "8cb2168b0a2607c216a4d9b81bc9e16088895fc5",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "src",
    "icons",
    "assets",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "axios": "^1.13.4"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-fetch",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "globalDependencies": {
      "axios": true
    },
    "onions": {
      "interceptor": {
        "optionsPackage": true,
        "optionsGlobalInterfaceName": "IDecoratorInterceptorOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-fetch",
        "boilerplate": "interceptor/boilerplate"
      }
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "axios"
          ],
          "output": "axios"
        }
      ]
    }
  }
}
