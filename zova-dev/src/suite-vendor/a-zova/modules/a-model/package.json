{
  "name": "zova-module-a-model",
  "version": "5.0.37",
  "gitHead": "73721393c1ea9a95539948d57ad692f2c004d7c7",
  "description": "core",
  "keywords": [
    "Zova Module"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "cli",
    "dist",
    "src",
    "icons",
    "assets",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@tanstack/query-core": "^5.94.5",
    "@tanstack/query-persist-client-core": "^5.94.5",
    "@tanstack/vue-query": "^5.94.5",
    "localforage": "^1.10.0",
    "mutate-on-copy": "^1.0.1",
    "table-identity": "^1.0.0"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-model",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "globalDependencies": {
      "@tanstack/query-core": true,
      "@tanstack/vue-query": true,
      "mutate-on-copy": true,
      "table-identity": true
    },
    "onions": {
      "model": {
        "sceneIsolate": true,
        "beanGeneral": true,
        "optionsGlobalInterfaceName": "IDecoratorModelOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-model",
        "boilerplate": "model/boilerplate"
      }
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@tanstack/query-core",
            "@tanstack/query-persist-client-core",
            "@tanstack/vue-query"
          ],
          "output": "tanstack-query"
        },
        {
          "match": [
            "localforage"
          ],
          "output": "localforage"
        }
      ]
    }
  }
}
