{
  "name": "zova-module-demo-basic",
  "version": "5.0.0",
  "description": "demo basic",
  "keywords": [
    "Zova Module"
  ],
  "author": "zhennann",
  "files": [
    "dist",
    "mock",
    "rest",
    "src",
    "icons",
    "assets"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {},
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..types[0]",
      "exports.\\..import"
    ]
  },
  "title": "demo-basic",
  "zovaModule": {
    "onionsConfig": {
      "aop": {
        "home": {
          "match": "home-index.controller.pageHome"
        },
        "home3": {
          "dependencies": "demo-basic:home",
          "match": "regexp:///home-index\\.controller\\.pageHome/"
        }
      }
    }
  }
}
