{
  "name": "zova-module-demo-basic",
  "version": "5.0.0",
  "description": "demo basic",
  "keywords": [
    "Zova Module"
  ],
  "author": "zhennann",
  "files": [
    "dist",
    "mock",
    "rest",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {},
  "dependencies": {},
  "title": "demo-basic",
  "zovaModule": {
    "onionsConfig": {
      "aop": {
        "home": {
          "match": "home-index.controller.pageHome"
        },
        "home3": {
          "dependencies": "demo-basic:home",
          "match": "regexp:///home-index\\.controller\\.pageHome/"
        }
      }
    }
  }
}
