{
  "name": "zova-dev",
  "description": "A vue3 framework with ioc",
  "author": "zhennann <zhen.nann@icloud.com>",
  "type": "module",
  "scripts": {
    "zova": "node ../zova-cli/cli/src/bin/zova.ts",
    "dev": "npm run dev:ssr:admin",
    "build": "npm run build:ssr:admin",
    "preview": "npm run preview:ssr:admin",
    "dev:ssr:admin": "npm run prerun && quasar dev --mode ssr --flavor admin",
    "dev:ssr:front": "npm run prerun && quasar dev --mode ssr --flavor front",
    "dev:ssr:vona": "npm run prerun && quasar dev --mode ssr --flavor vona",
    "build:ssr:admin": "npm run prerun && quasar build --mode ssr --flavor admin",
    "build:ssr:front": "npm run prerun && quasar build --mode ssr --flavor front",
    "build:ssr:vona": "npm run prerun && quasar build --mode ssr --flavor vona",
    "preview:ssr:admin": "concurrently \"cd ./dist-mock && node index.js\" \"node ./dist/ssr-admin/index.js\"",
    "preview:ssr:front": "concurrently \"cd ./dist-mock && node index.js\" \"node ./dist/ssr-front/index.js\"",
    "preview:ssr:vona": "concurrently \"cd ./dist-mock && node index.js\" \"node ./dist/ssr-vona/index.js\"",
    "dev:spa": "npm run prerun && quasar dev --mode spa --flavor admin",
    "build:spa": "npm run prerun && quasar build --mode spa --flavor admin",
    "preview:spa": "vite preview --outDir=dist/spa",
    "build:githubpages": "npm run prerun && quasar build --mode spa --flavor githubpages",
    "prerun": "npm run zova :tools:deps && npm run tsc",
    "tsc": "vue-tsc --noEmit --project tsconfig.vue-tsc.json",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "keywords": ["vue3", "ioc", "zova"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "autoprefixer": "^10.4.20",
    "compression": "^1.7.5",
    "connect": "^3.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "daisyui": "^4.12.22",
    "postcss": "^8.4.49",
    "quasar": "^2.18.1",
    "tailwindcss": "^3.4.17",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5",
    "zova": "workspace:^"
  },
  "devDependencies": {
    "@cabloy/lint": "^5.0.8",
    "@quasar/app-vite": "2.2.0",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.20.1",
    "openapi-typescript": "^7.4.4",
    "quasar-app-extension-zova": "workspace:^",
    "sass": "^1.81.0",
    "typescript": "5.7.3",
    "vite": "^6.2.4",
    "vue-tsc": "^2.2.0",
    "zova-openapi": "workspace:^",
    "zova-vite": "workspace:^"
  },
  "license": "MIT"
}
