{
  "extends": "./tsconfig.base.esm",
  "compilerOptions": {
    "composite": false,
    "allowImportingTsExtensions": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "rewriteRelativeImportExtensions": false,
    "verbatimModuleSyntax": false
  },
  "references": [
  ],
  "exclude": [
    "**/cli/**",
    "**/dist/**",
    "./dist",
    "./distMockServer",
    "./.quasar",
    "./.zova",
    "./node_modules",
    "./src-capacitor",
    "./src-cordova",
    "./quasar.config.*.temporary.compiled*",
    "./src/boot/app",
    "./src/boot/main.ts",
    "./packages-utils",
    "./packages-zova"
  ]
}
