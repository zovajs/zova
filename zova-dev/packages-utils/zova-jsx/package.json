{
  "name": "zova-jsx",
  "version": "1.1.6",
  "gitHead": "f3ee206cee7d9b738f6603531beeec0bfa46ffa6",
  "description": "Zova JSX",
  "keywords": [
    "ioc",
    "vue3",
    "zova"
  ],
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "license": "MIT",
  "author": "zhennann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/compose": "^2.0.4",
    "@cabloy/utils": "^2.0.23",
    "@cabloy/word-utils": "^2.1.5",
    "typestyle": "^2.4.0",
    "vue": "^3.5.6",
    "zova-core": "^5.1.6"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..types[0]",
      "exports.\\..import",
      "exports.\\..require"
    ]
  }
}
