{
  "name": "quasar-app-extension-zova",
  "version": "1.2.18",
  "gitHead": "4d11b0fed7af50b828971785af3c014046be6afa",
  "description": "Quasar ext of zova",
  "author": "zhennann",
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/index.js": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@quasar/app-vite": "npm:@cabloy/quasar-app-vite@^2.5.9",
    "chalk": "^3.0.0",
    "esbuild": "^0.25.12",
    "fs-extra": "^11.3.4",
    "vite": "^8.0.8",
    "zova-vite": "^1.1.18"
  },
  "devDependencies": {
    "@cabloy/lint": "^5.1.5",
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  }
}
