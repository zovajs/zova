{
  "name": "quasar-app-extension-zova",
  "version": "1.2.11",
  "gitHead": "8cb2168b0a2607c216a4d9b81bc9e16088895fc5",
  "description": "Quasar ext of zova",
  "author": "zhennann",
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dist/index.js": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@quasar/app-vite": "2.5.2",
    "chalk": "^3.0.0",
    "esbuild": "^0.25.2",
    "fs-extra": "^11.2.0",
    "vite": "^8.0.1",
    "zova-vite": "^1.1.11"
  },
  "devDependencies": {
    "@cabloy/lint": "^5.0.24",
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  }
}
