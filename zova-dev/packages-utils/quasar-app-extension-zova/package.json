{
  "name": "quasar-app-extension-zova",
  "type": "module",
  "version": "1.1.184",
  "description": "Quasar ext of zova",
  "author": "zhennann",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "templates"
  ],
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "scripts",
      "exports.\\..import"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@quasar/app-vite": "2.2.0",
    "chalk": "^3.0.0",
    "esbuild": "^0.23.0",
    "fs-extra": "^11.2.0",
    "vite": "^5.2.10",
    "vite-node": "^2.0.5",
    "zova-openapi": "^1.0.0",
    "zova-shared": "^1.0.7",
    "zova-vite": "^1.0.182"
  },
  "devDependencies": {
    "@cabloy/lint": "^5.0.0",
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "gitHead": "c90e59abc1bf445154a3fb32856f83783dc0eb39"
}
