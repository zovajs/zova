{
  "name": "zova-vite",
  "type": "module",
  "version": "1.0.182",
  "description": "zova vite",
  "publishConfig": {
    "access": "public"
  },
  "author": "zhennann",
  "license": "MIT",
  "keywords": [
    "framework",
    "zova"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "templates"
  ],
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "scripts",
      "exports.\\..import"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc -b",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@babel/plugin-proposal-decorators": "^7.24.1",
    "@babel/plugin-transform-class-properties": "^7.24.1",
    "@cabloy/dotenv": "^1.0.2",
    "@cabloy/extend": "^3.0.5",
    "@cabloy/module-glob": "^5.1.12",
    "@cabloy/module-info": "^1.2.10",
    "@cabloy/vite-plugin-babel": "^1.1.3",
    "@cabloy/vue-babel-plugin-jsx": "^1.2.5",
    "@cabloy/vue-compiler-sfc": "^3.5.14",
    "@cabloy/vue-reactivity": "^3.5.16",
    "@cabloy/vue-router": "^4.4.8",
    "@cabloy/vue-runtime-core": "^3.5.18",
    "@cabloy/vue-runtime-dom": "^3.5.13",
    "@faker-js/faker": "^8.4.1",
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "babel-plugin-transform-typescript-metadata": "^0.3.2",
    "babel-plugin-zova-bean-module": "^1.0.32",
    "babel-plugin-zova-bean-use": "^1.0.3",
    "babel-plugin-zova-behavior": "^1.0.0",
    "babel-plugin-zova-component": "^1.0.3",
    "chalk": "^3.0.0",
    "esbuild": "^0.23.0",
    "fs-extra": "^11.2.0",
    "lodash": "^4.17.21",
    "minimist": "^1.2.8",
    "module-alias": "^2.2.3",
    "terser": "^5.31.0",
    "tmp": "^0.2.3",
    "vite": "^5.2.11",
    "vite-plugin-fake-server-turbo": "^2.1.3",
    "zova-shared": "^1.0.7"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.7",
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "gitHead": "c90e59abc1bf445154a3fb32856f83783dc0eb39"
}
