import { sys } from 'zova';
import { locales } from '../../src/front/config/locales.js';
<%=sysMonkey?"import { SysMonkey } from '../../src/front/config/monkeySys.js';":''%>
<%=appMonkey?"import { AppMonkey } from '../../src/front/config/monkey.js';":''%>
<%=legacy?"import { routes as legacyRoutes } from '../../src/legacy/routes.js';":''%>
import config from '../config.js';
import { modulesMeta } from '../modules-meta.js';

export function getPluginZovaOptions() {
  return {
    modulesMeta, 
    locales,
    config,
    <%=sysMonkey?'SysMonkey,':''%>
    <%=appMonkey?'AppMonkey,':''%>
    <%=legacy?'legacyRoutes,':''%>
  };
}

export async function resolveRoute(req: any) {
  // router
  const sysRouter = await getSysRouter();
  // resolve
  sysRouter.resolve(req.url);
}

let _sysRouter;
async function getSysRouter() {
  if (!_sysRouter) {
    // sys
    await sys.initialize(getPluginZovaOptions());
    // router
    _sysRouter = await sys.bean._getBean('a-router.sys.router', false);
  }
  return _sysRouter;
}
