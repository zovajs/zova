{
  "name": "mutate-on-copy",
  "version": "1.1.4",
  "gitHead": "f3ee206cee7d9b738f6603531beeec0bfa46ffa6",
  "description": "mutate on copy",
  "keywords": [
    "framework",
    "zova"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..types[0]",
      "exports.\\..import",
      "exports.\\..require"
    ]
  }
}
