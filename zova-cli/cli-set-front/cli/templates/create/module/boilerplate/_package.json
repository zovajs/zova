{
  "name": "zova-module-<%=argv.name%>",
  "version": "5.0.0",
  "title": "<%=argv.moduleInfo.relativeName%>",
  "type": "module",
  "exports": {
    ".": {
      "types": ["./src/index.ts", "./dist/index.d.ts"],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "description": "<%=argv.description%>",
  "keywords": ["Zova Module"],
  "author": "<%=argv.author%>",
  "files": ["mock", "dist", "src", "icons", "assets", "rest"],
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {},
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..types[0]",
      "exports.\\..import"
    ]
  }
}
