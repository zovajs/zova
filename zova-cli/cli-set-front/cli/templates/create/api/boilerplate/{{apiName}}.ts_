import { Api, BeanApiBase } from 'zova-module-a-api';

export interface Api<%=argv.nameMeta.fullCapitalize%>EchoResult {
  message: string;
}

@Api()
export class Api<%=argv.nameMeta.fullCapitalize%> extends BeanApiBase {
  echo() {
    return this.$fetch.get<any, Api<%=argv.nameMeta.fullCapitalize%>EchoResult>('/<%=argv.apiName%>/echo');
  }
}
