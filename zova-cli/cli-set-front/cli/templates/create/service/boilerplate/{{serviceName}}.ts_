import { Service } from 'zova';
import { BeanServiceBase } from 'zova-module-a-api';

export interface Service<%=argv.nameMeta.fullCapitalize%>EchoResult {
  message: string;
}

@Service()
export class Service<%=argv.nameMeta.fullCapitalize%> extends BeanServiceBase {
  echo() {
    return this.$api.get<any, Service<%=argv.nameMeta.fullCapitalize%>EchoResult>('/<%=argv.serviceName%>/echo');
  }
}
