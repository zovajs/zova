{
  "name": "zova-cli-set-front",
  "type": "module",
  "version": "1.1.199",
  "description": "zova cli-set-front",
  "publishConfig": {
    "access": "public"
  },
  "author": "zhennann",
  "license": "MIT",
  "keywords": [
    "framework",
    "zova"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "cli",
    "dist"
  ],
  "clean-package": {
    "indent": 2,
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..require"
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/cli": "^3.0.34",
    "@cabloy/extend": "^3.1.0",
    "@cabloy/module-info": "^1.3.22",
    "@cabloy/utils": "^1.0.37",
    "@cabloy/word-utils": "^2.0.0",
    "compressing": "^1.10.0",
    "fs-extra": "^11.2.0",
    "globby": "^14.1.0",
    "gogocode": "^1.0.55",
    "openapi-typescript": "^7.6.1",
    "rimraf": "^5.0.5",
    "svgo": "^3.2.0",
    "typescript": "5.7.3",
    "urllib": "^4.6.11",
    "zova-openapi": "^1.0.3",
    "zova-shared": "^1.0.7",
    "zova-vite": "^1.0.182"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.0.1"
  },
  "gitHead": "cd764f950253da76034e90e5b93f2cd1cfe2733f"
}
