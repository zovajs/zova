{
  "name": "zova-cli-set-front",
  "version": "1.2.24",
  "gitHead": "4d11b0fed7af50b828971785af3c014046be6afa",
  "description": "zova cli-set-front",
  "keywords": [
    "framework",
    "zova"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "cli",
    "dist",
    "dist-cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist dist-cli tsconfig.build.tsbuildinfo tsconfig.cli.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral && tsc -p tsconfig.build.json && tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@cabloy/cli": "^3.0.105",
    "@cabloy/extend": "^3.1.0",
    "@cabloy/module-info": "^2.0.0",
    "@cabloy/openapi-typescript": "^7.9.2",
    "@cabloy/utils": "^2.0.21",
    "@cabloy/vite-plugin-babel": "^1.3.3",
    "@cabloy/vue-babel-plugin-jsx": "^2.0.1",
    "@cabloy/word-utils": "^2.1.8",
    "@typescript/native-preview": "^7.0.0-dev.20260320.1",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "babel-plugin-transform-typescript-metadata": "^0.4.0",
    "babel-plugin-zova-bean-module": "^1.2.8",
    "babel-plugin-zova-bean-use": "^1.1.8",
    "babel-plugin-zova-behavior": "^1.1.8",
    "babel-plugin-zova-component": "^1.1.8",
    "compressing": "^1.10.0",
    "fs-extra": "^11.2.0",
    "globby": "^14.1.0",
    "gogocode": "^1.0.55",
    "rimraf": "^5.0.5",
    "rolldown": "^1.0.0-rc.11",
    "rolldown-plugin-dts": "^0.22.5",
    "svgo": "^3.2.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "urllib": "^4.6.11",
    "vite": "^8.0.2",
    "yaml": "^2.8.3",
    "zova-openapi": "^1.1.8",
    "zova-vite": "^1.1.14"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..require"
    ]
  }
}
