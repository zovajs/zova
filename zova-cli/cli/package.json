{
  "name": "zova-cli",
  "version": "1.2.25",
  "gitHead": "4d11b0fed7af50b828971785af3c014046be6afa",
  "description": "zova cli",
  "keywords": [
    "framework",
    "zova"
  ],
  "license": "MIT",
  "author": "zhennann",
  "bin": {
    "zova": "dist/bin/zova.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/cli": "^3.0.105",
    "@cabloy/process-helper": "^3.0.0",
    "fs-extra": "^11.2.0",
    "semver": "^7.6.2",
    "zova-cli-set-front": "^1.2.25"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..require"
    ]
  }
}
