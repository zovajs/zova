{
  "name": "@cabloy/logger",
  "version": "1.1.12",
  "gitHead": "6f675a8cc46d596142c591c28a40cc4d82fcc6cc",
  "description": "logger",
  "keywords": [
    "framework",
    "zova"
  ],
  "license": "MIT",
  "author": "zhennann",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "tsc:publish": "npm run clean && vona :bin:buildGeneral && tsc",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  },
  "dependencies": {
    "@cabloy/localeutil": "^2.1.3",
    "fecha": "^4.2.3"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import",
      "exports.\\..require"
    ]
  }
}
