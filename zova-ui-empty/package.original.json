{
  "name": "zova-ui-empty",
  "version": "5.1.3",
  "packageManager": "pnpm@10.19.0",
  "description": "A vue3 empty framework with ioc",
  "publishConfig": {
    "access": "public"
  },
  "author": "zhennann",
  "type": "module",
  "scripts": {
    "init": "pnpm install --no-frozen-lockfile && zova :tools:deps",
    "dev": "npm run dev:ssr:admin",
    "build": "npm run build:ssr:admin",
    "preview": "npm run preview:ssr:admin",
    "dev:spa": "npm run prerun && quasar dev --mode spa --flavor admin",
    "build:spa": "npm run prerun && quasar build --mode spa --flavor admin",
    "preview:spa": "vite preview --outDir=dist/spa-admin",
    "prerun": "zova :tools:deps && npm run tsc",
    "tsc": "tsc --noEmit --project tsconfig.vue-tsc.json",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev:ssr:admin": "npm run prerun && quasar dev --mode ssr --flavor admin",
    "build:ssr:admin": "npm run prerun && quasar build --mode ssr --flavor admin",
    "preview:ssr:admin": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-admin/index.js\"",
    "dev:ssr:web": "npm run prerun && quasar dev --mode ssr --flavor web",
    "build:ssr:web": "npm run prerun && quasar build --mode ssr --flavor web",
    "preview:ssr:web": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-web/index.js\""
  },
  "keywords": ["vue3", "ioc", "zova"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "connect": "^3.7.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "quasar": "^2.18.1",
    "vue": "^3.5.6",
    "vue-router": "^4.4.5",
    "zova": "^5.1.4"
  },
  "devDependencies": {
    "@cabloy/lint": "^5.0.24",
    "@cabloy/openapi-typescript": "^7.9.2",
    "@quasar/app-vite": "2.4.0",
    "@types/node": "^22.10.2",
    "concurrently": "^8.2.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "quasar-app-extension-zova": "^1.2.2",
    "sass": "^1.77.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-fake-server-turbo": "^3.0.15",
    "vue-tsc": "^3.2.4",
    "zova-openapi": "^1.1.2",
    "zova-vite": "^1.1.2"
  },
  "license": "MIT",
  "gitHead": "a1b13b06e259e4447ab2f361ec76941810bc4ad7"
}
