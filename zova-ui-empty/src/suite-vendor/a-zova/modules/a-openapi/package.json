{
  "name": "zova-module-a-openapi",
  "version": "5.0.0",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "dist",
    "mock"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {
    "@cabloy/json-schema-to-zod": "^2.6.4",
    "@zhennann/currency": "^2.0.4",
    "openapi3-ts": "^4.5.0"
  },
  "title": "a-openapi",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {
      "a-model": "5.0.0"
    },
    "globalDependencies": {
      "openapi3-ts": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@cabloy/json-schema-to-zod",
            "openapi3-ts"
          ],
          "output": "openapi3"
        }
      ]
    }
  }
}
