{
  "plugins": {},
  "filters": {},
  "rules": {
    "ja-no-mixed-period": {
      "periodMark": "。",
      "forceAppendPeriod": true,
      "allowPeriodMarks": ["?", "!", ":", "？", "！", "："]
    },
    "en-no-mixed-period": {
      "periodMark": ".",
      "forceAppendPeriod": true,
      "allowPeriodMarks": ["?", "!", ":", "？", "！", "：", "。"]
    },
    "ja-space-between-half-and-full-width": {
      "space": "always"
    },
    "textlint-rule-period-in-list-item": {
      "periodMark": "",
      "forceAppendPeriod": true
    }
  }
}
