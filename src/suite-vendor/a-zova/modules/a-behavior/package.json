{
  "name": "zova-module-a-behavior",
  "version": "5.1.14",
  "gitHead": "6f675a8cc46d596142c591c28a40cc4d82fcc6cc",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "src",
    "icons",
    "assets",
    "dist-cli"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist dist-cli tsconfig.build.tsbuildinfo tsconfig.cli.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json && tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-behavior",
  "zovaModule": {
    "onions": {
      "behavior": {
        "optionsGlobalInterfaceName": "IDecoratorBehaviorOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-behavior",
        "boilerplate": "behavior/boilerplate",
        "metadataCustom": "behavior/metadata/generate.ts"
      }
    }
  }
}
