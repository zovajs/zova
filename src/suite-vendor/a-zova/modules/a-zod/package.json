{
  "name": "zova-module-a-zod",
  "version": "5.1.18",
  "gitHead": "6f675a8cc46d596142c591c28a40cc4d82fcc6cc",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "dist",
    "mock",
    "src",
    "icons",
    "assets"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.build.tsbuildinfo",
    "tsc:publish": "npm run clean && zova :bin:buildModule --sourcemap && tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run tsc:publish",
    "prepack": "clean-package",
    "postpack": "clean-package restore && npm run clean"
  },
  "dependencies": {
    "@cabloy/zod-errors-custom": "^2.1.3",
    "@cabloy/zod-openapi": "^1.1.6",
    "@cabloy/zod-query": "^2.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "clean-package": "^2.2.0",
    "rimraf": "^6.1.3"
  },
  "clean-package": {
    "indent": 2,
    "replace": {
      "exports.\\..types": "./dist/index.d.ts"
    },
    "remove": [
      "clean-package",
      "devDependencies",
      "exports.\\..import"
    ]
  },
  "title": "a-zod",
  "zovaModule": {
    "globalDependencies": {
      "@cabloy/zod-openapi": true,
      "zod": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@cabloy/zod-errors-custom",
            "@cabloy/zod-openapi",
            "@cabloy/zod-query",
            "zod/locales",
            "zod/v4",
            "~node_modules/zod/index.js",
            "@cabloy/zod/locales",
            "@cabloy/zod/v4",
            "~node_modules/@cabloy/zod/index.js"
          ],
          "output": "zod"
        }
      ]
    }
  }
}
