{
  "name": "zova-ui-vuetify",
  "version": "5.1.14",
  "gitHead": "8cb2168b0a2607c216a4d9b81bc9e16088895fc5",
  "description": "A vue3 vuetify framework with ioc",
  "keywords": [
    "ioc",
    "vue3",
    "zova"
  ],
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "license": "MIT",
  "author": "zhennann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "init": "pnpm install --no-frozen-lockfile && zova :tools:deps",
    "dev": "npm run dev:ssr:admin",
    "build": "npm run build:ssr:admin",
    "preview": "npm run preview:ssr:admin",
    "dev:spa": "npm run prerun && quasar dev --mode spa --flavor admin",
    "build:spa": "npm run prerun && quasar build --mode spa --flavor admin",
    "preview:spa": "vite preview --outDir=dist/spa-admin",
    "prerun": "zova :tools:deps && npm run tsc",
    "tsc": "tsc --noEmit --project tsconfig.vue-tsc.json",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev:ssr:admin": "npm run prerun && quasar dev --mode ssr --flavor admin",
    "build:ssr:admin": "npm run prerun && quasar build --mode ssr --flavor admin",
    "preview:ssr:admin": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-admin/index.js\"",
    "dev:ssr:web": "npm run prerun && quasar dev --mode ssr --flavor web",
    "build:ssr:web": "npm run prerun && quasar build --mode ssr --flavor web",
    "preview:ssr:web": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-web/index.js\"",
    "dev:ssr:cabloyStartAdmin": "npm run prerun && quasar dev --mode ssr --flavor cabloyStartAdmin",
    "build:ssr:cabloyStartAdmin": "npm run prerun && quasar build --mode ssr --flavor cabloyStartAdmin",
    "build:rest:cabloyStartAdmin": "npm run prerun && zova :bin:buildRest -- --flavor cabloyStartAdmin",
    "preview:ssr:cabloyStartAdmin": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-cabloyStartAdmin/index.js\"",
    "dev:spa:cabloyStartAdmin": "npm run prerun && quasar dev --mode spa --flavor cabloyStartAdmin",
    "dev:ssr:cabloyStartWeb": "npm run prerun && quasar dev --mode ssr --flavor cabloyStartWeb",
    "build:ssr:cabloyStartWeb": "npm run prerun && quasar build --mode ssr --flavor cabloyStartWeb",
    "build:rest:cabloyStartWeb": "npm run prerun && zova :bin:buildRest -- --flavor cabloyStartWeb",
    "preview:ssr:cabloyStartWeb": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-cabloyStartWeb/index.js\"",
    "dev:spa:cabloyStartWeb": "npm run prerun && quasar dev --mode spa --flavor cabloyStartWeb"
  },
