{
  "name": "zova-module-a-table",
  "version": "5.0.0",
  "description": "",
  "keywords": [
    "Zova Module"
  ],
  "author": "",
  "files": [
    "cli",
    "dist",
    "mock",
    "rest"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/vue-table": "^8.21.3"
  },
  "title": "a-table",
  "zovaModule": {
    "globalDependencies": {
      "@tanstack/table-core": true,
      "@tanstack/vue-table": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@tanstack/table-core",
            "@tanstack/vue-table"
          ],
          "output": "tanstack-table"
        }
      ]
    },
    "onions": {
      "tableCell": {
        "beanGeneral": true,
        "optionsGlobalInterfaceName": "IDecoratorTableCellOptions",
        "optionsGlobalInterfaceFrom": "zova-module-a-table",
        "boilerplate": "cli/tableCell/boilerplate",
        "metadataCustom": "cli/tableCell/metadata/generate.ts"
      }
    }
  }
}
