{
  "name": "zova-module-a-form",
  "type": "module",
  "version": "5.0.0",
  "title": "a-form",
  "zovaModule": {
    "globalDependencies": {
      "@tanstack/vue-form": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "@tanstack/vue-form"
          ],
          "output": "tanstack-form"
        }
      ]
    }
  },
  "description": "",
  "author": "",
  "keywords": [
    "Zova Module"
  ],
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist",
    "mock",
    "rest"
  ],
  "scripts": {
    "clean": "tsc -b --clean",
    "tsc:publish": "npm run clean && tsc -b",
    "_prepublishOnly": "npm run tsc:publish"
  },
  "dependencies": {
    "@tanstack/vue-form": "^1.23.5"
  }
}
