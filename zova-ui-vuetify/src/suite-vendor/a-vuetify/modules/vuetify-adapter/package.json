{
  "name": "zova-module-vuetify-adapter",
  "version": "5.0.0",
  "description": "vuetify",
  "keywords": [
    "Zova Module"
  ],
  "author": "zhennann",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": [
        "./src/index.ts",
        "./dist/index.d.ts"
      ],
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {},
  "dependencies": {
    "@date-io/core": "^3.2.0",
    "@date-io/luxon": "^3.2.0"
  },
  "title": "vuetify-adapter",
  "zovaModule": {
    "capabilities": {
      "monkey": true
    },
    "dependencies": {
      "a-zova": "5.0.0"
    },
    "globalDependencies": {
      "@date-io/luxon": true
    },
    "bundle": {
      "vendors": [
        {
          "match": [
            "vuetify/lib"
          ],
          "output": "vuetify"
        },
        {
          "match": [
            "@date-io/core",
            "@date-io/luxon"
          ],
          "output": "date-io-luxon"
        }
      ]
    }
  }
}
