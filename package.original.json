{
  "name": "zova",
  "private": true,
  "description": "A vue3 framework with ioc",
  "keywords": [
    "ioc",
    "vue3",
    "zova"
  ],
  "homepage": "https://github.com/zovajs/zova#readme",
  "bugs": {
    "url": "https://github.com/zovajs/zova/issues"
  },
  "license": "MIT",
  "author": "zhennann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zovajs/zova.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "init": "pnpm install --no-frozen-lockfile && npm run zova :tools:deps",
    "zova": "node ../zova-cli/cli/src/bin/zova.ts",
    "dev": "npm run dev:ssr:admin",
    "build": "npm run build:ssr:admin",
    "preview": "npm run preview:ssr:admin",
    "dev:spa": "npm run prerun && quasar dev --mode spa --flavor admin",
    "build:spa": "npm run prerun && quasar build --mode spa --flavor admin",
    "preview:spa": "vite preview --outDir=dist/spa-admin",
    "build:githubpages": "npm run prerun && quasar build --mode spa --flavor githubpages",
    "prerun": "npm run zova :tools:deps && npm run tsc",
    "tsc": "tsc --noEmit --project tsconfig.vue-tsc.json",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "docs:fix": "textlint --fix ./zova-docs/**/*.md",
    "release-patch": "./scripts/release.sh patch",
    "release-minor": "./scripts/release.sh minor",
    "dev:ssr:admin": "npm run prerun && quasar dev --mode ssr --flavor admin",
    "build:ssr:admin": "npm run prerun && quasar build --mode ssr --flavor admin",
    "preview:ssr:admin": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-admin/index.js\"",
    "dev:ssr:web": "npm run prerun && quasar dev --mode ssr --flavor web",
    "build:ssr:web": "npm run prerun && quasar build --mode ssr --flavor web",
    "preview:ssr:web": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-web/index.js\"",
    "dev:ssr:cabloyBasicAdmin": "npm run prerun && quasar dev --mode ssr --flavor cabloyBasicAdmin",
    "build:ssr:cabloyBasicAdmin": "npm run prerun && quasar build --mode ssr --flavor cabloyBasicAdmin",
    "build:rest:cabloyBasicAdmin": "npm run prerun && npm run zova :bin:buildRest -- --flavor cabloyBasicAdmin",
    "preview:ssr:cabloyBasicAdmin": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-cabloyBasicAdmin/index.js\"",
    "dev:spa:cabloyBasicAdmin": "npm run prerun && quasar dev --mode spa --flavor cabloyBasicAdmin",
    "dev:ssr:testSecond": "npm run prerun && quasar dev --mode ssr --flavor testSecond",
    "build:ssr:testSecond": "npm run prerun && quasar build --mode ssr --flavor testSecond",
    "build:rest:testSecond": "npm run prerun && npm run zova :bin:buildRest -- --flavor testSecond",
    "preview:ssr:testSecond": "concurrently \"node ./dist-mock/index.js\" \"node ./dist/ssr-testSecond/index.js\"",
    "dev:spa:testSecond": "npm run prerun && quasar dev --mode spa --flavor testSecond",
    "build:ssr:cabloyBasicBatch": "npm run build:ssr:cabloyBasicAdmin && npm run build:rest:cabloyBasicAdmin",
    "build:ssr:testSecondBatch": "npm run build:ssr:testSecond && npm run build:rest:testSecond",
  },
  "keywords": ["vue3", "ioc", "zova"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cabloy/zova.git"
  },
  "homepage": "https://github.com/cabloy/zova#readme",
  "bugs": {
    "url": "https://github.com/cabloy/zova/issues"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.27",
    "compression": "^1.8.1",
    "connect": "^3.7.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.9",
    "quasar": "^2.19.3",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "npm:@cabloy/vue-router@^4.4.16",
    "zova": "workspace:^"
  },
  "devDependencies": {
    "@cabloy/lint": "^5.1.15",
    "@cabloy/openapi-typescript": "^7.9.2",
    "@quasar/app-vite": "npm:@cabloy/quasar-app-vite@^2.5.9",
    "@types/node": "^22.19.17",
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^8.2.2",
    "quasar-app-extension-zova": "workspace:^",
    "sass": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-plugin-fake-server-turbo": "^3.0.18",
    "vue-tsc": "^3.2.6",
    "zova-vite": "workspace:^",
    "lerna": "^9.0.7",
    "textlint": "^15.7.0",
    "textlint-rule-en-no-mixed-period": "^3.0.2",
    "textlint-rule-ja-no-mixed-period": "^3.0.2",
    "textlint-rule-ja-space-between-half-and-full-width": "^2.4.2",
    "textlint-rule-period-in-list-item": "^1.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.65.0"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.19.0",
  "pnpm": {
    "overrides": {
      "@quasar/app-vite": "npm:@cabloy/quasar-app-vite@^2.5.9",
      "@vue/babel-plugin-jsx": "npm:@cabloy/vue-babel-plugin-jsx@^2.0.1",
      "@vue/compiler-sfc": "npm:@cabloy/vue-compiler-sfc@^3.5.14",
      "@vue/runtime-core": "npm:@cabloy/vue-runtime-core@^3.5.52",
      "@vue/runtime-dom": "npm:@cabloy/vue-runtime-dom@^3.5.13",
      "@vue/reactivity": "npm:@cabloy/vue-reactivity@^3.5.16",
      "@vue/server-renderer": "npm:@cabloy/vue-server-renderer@^3.5.18",
      "vue-router": "npm:@cabloy/vue-router@^4.4.16",
      "zod": "npm:@cabloy/zod@4.3.6"
    }
  }
}
